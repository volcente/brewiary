{
  "name": "brewiary",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "compile": "next build --experimental-build-mode compile",
    "start": "next start",
    "lint": "next lint",
    "db:codegen": "kysely-codegen --env-file=.env.local",
    "db:codegen-ci": "kysely-codegen",
    "db:validate": "kysely-codegen --verify=true --env-file=.env.local",
    "db:validate-ci": "kysely-codegen --verify=true",
    "db:seed": "tsx src/db/seed.ts",
    "db:migration": "tsx src/db/migration.ts",
    "db:migrate-up": "tsx src/db/migrate-up.ts",
    "db:migrate-down": "tsx src/db/migrate-down.ts",
    "db:migrate-latest": "tsx src/db/migrate-latest.ts",
    "ci:migrate-and-seed": "pnpm db:migrate-latest && pnpm db:seed",
    "ci:codegen-and-validate": "pnpm db:codegen-ci && pnpm db:validate-ci",
    "ci:build": "pnpm ci:migrate-and-seed && pnpm ci:codegen-and-validate && pnpm build"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "kysely": "^0.28.2",
    "lucide-react": "^0.513.0",
    "next": "15.3.2",
    "next-themes": "^0.4.6",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@faker-js/faker": "^9.8.0",
    "@next/eslint-plugin-next": "^15.3.3",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.3.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jiti": "^2.4.2",
    "kysely-codegen": "^0.18.5",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
